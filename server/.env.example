NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/career_guidance
MONGODB_URI=mongodb://localhost:27017/career_guidance
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Gemini: copy these lines to server/.env with your real keys ---
GEMINI_CHAT_API_KEY=your-gemini-chat-api-key
GEMINI_RECOMMEND_API_KEY=your-gemini-recommend-api-key
GEMINI_COMPARE_API_KEY=your-gemini-compare-api-key
GEMINI_RESUME_API_KEY=your-gemini-resume-api-key
# Optional dedicated keys (fallback to core keys when omitted):
GEMINI_INTERNSHIP_API_KEY=your-gemini-internship-api-key
GEMINI_PROJECT_API_KEY=your-gemini-project-api-key
GEMINI_ANALYTICS_API_KEY=your-gemini-analytics-api-key
GEMINI_ROADMAP_API_KEY=your-gemini-roadmap-api-key
# Or one shared fallback for all agents:
# GEMINI_SHARED_API_KEY=your-shared-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-flash-latest,gemini-2.5-flash,gemini-2.0-flash-lite
GEMINI_REQUEST_TIMEOUT_MS=45000
GEMINI_STARTUP_PROBE=true
AI_RATE_LIMIT_MAX=40
AI_PROFILE_RATE_LIMIT_MAX=60
