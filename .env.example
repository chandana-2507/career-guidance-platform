# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/career-guidance

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI (legacy features only)
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================
# Multi-Agent Gemini API Keys (one key per AI module)
# Create separate keys in Google AI Studio for quota isolation.
# ============================================================
GEMINI_CHAT_API_KEY=your-gemini-chat-api-key
GEMINI_RECOMMEND_API_KEY=your-gemini-recommend-api-key
GEMINI_COMPARE_API_KEY=your-gemini-compare-api-key
GEMINI_RESUME_API_KEY=your-gemini-resume-api-key
GEMINI_INTERNSHIP_API_KEY=your-gemini-internship-api-key
GEMINI_PROJECT_API_KEY=your-gemini-project-api-key
GEMINI_ANALYTICS_API_KEY=your-gemini-analytics-api-key
GEMINI_ROADMAP_API_KEY=your-gemini-roadmap-api-key

# Shared Gemini model settings (all agents)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-flash-latest,gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_REQUEST_TIMEOUT_MS=45000
GEMINI_STARTUP_PROBE=true

# Rate limiting
AI_RATE_LIMIT_MAX=40
AI_PROFILE_RATE_LIMIT_MAX=60
